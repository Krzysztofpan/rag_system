# Backend
BACKEND_PORT=8000
APP_ENV=development

# Supabase — session pooler (port 5432), recommended for FastAPI + SQLModel + Alembic
# Settings → Database → Connection string → Session pooler
DATABASE_PASSWORD=YOUR_PASSWORD
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:${DATABASE_PASSWORD}@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# Parser (ComplexParser: Docling + OCR repair + guarded LLM repair)
# OPENAI_API_KEY=
# PARSER_LLM_MODEL=gpt-4o-mini
# PARSER_OCR_REPAIR=true
# PARSER_LLM_REPAIR=true

# Future phases
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=
